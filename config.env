#!/usr/bin/env bash
# ════════════════════════════════════════════════════════════════════
#  Демоэкзамен 2026 · КОД 09.02.06-1-2026 · Модуль 1
#  Единый конфиг для всех устройств. Правь ТОЛЬКО этот файл под свой стенд.
# ════════════════════════════════════════════════════════════════════

# ── Домен ──
DOMAIN="au-team.irpo"

# ── Имена интерфейсов (!!! ПОДСТАВЬ ПОД СВОЙ СТЕНД — узнать: ip -br link !!!)
#  На Альт JeOS/Server обычно ens18/ens19/eth0. Первый — внешний (к ISP/uplink).
IF_EXT="ens18"     # внешний интерфейс (uplink / к ISP)
IF_INT="ens19"     # внутренний (trunk на HQ-RTR / LAN на остальных)

# ── ISP-линки (/28) ──
ISP_UPLINK_DHCP=1            # внешний интерфейс ISP получает адрес по DHCP
ISP_HQ_IP="172.16.1.1";  ISP_HQ_PFX="28"   # ISP -> HQ-RTR
ISP_BR_IP="172.16.2.1";  ISP_BR_PFX="28"   # ISP -> BR-RTR
HQ_ISP_IP="172.16.1.2";  HQ_ISP_PFX="28"   # HQ-RTR -> ISP
BR_ISP_IP="172.16.2.2";  BR_ISP_PFX="28"   # BR-RTR -> ISP

# ── HQ: VLAN-сегменты (router-on-a-stick на HQ-RTR) ──
# VLAN 100 — серверы, не более 32 адресов → /27
VL100_ID="100"; VL100_PFX="27"; VL100_RTR="192.168.100.1";  HQ_SRV_IP="192.168.100.10"
# VLAN 200 — клиенты, не менее 16 адресов → /28  (DHCP)
VL200_ID="200"; VL200_PFX="28"; VL200_RTR="192.168.200.1";  VL200_NET="192.168.200.0"
# VLAN 999 — управление, не более 8 адресов → /29
VL999_ID="999"; VL999_PFX="29"; VL999_RTR="192.168.99.1"

# ── BR: LAN-сегмент (не более 16 адресов → /28) ──
BR_PFX="28"; BR_RTR_LAN="192.168.110.1";   BR_SRV_IP="192.168.110.10"

# ── IP-туннель HQ <-> BR (GRE или IPIP) ──
TUN_TYPE="gre"             # gre | ipip
TUN_HQ_IP="10.10.10.1"
TUN_BR_IP="10.10.10.2"
TUN_PFX="30"

# ── Динамическая маршрутизация (OSPF через FRR), парольная защита ──
OSPF_AREA="0"
OSPF_KEY_ID="1"
OSPF_PASS="P@ssw0rd"       # MD5-ключ OSPF

# ── Учётные записи ──
SSH_USER="sshuser"; SSH_UID="2026"
NET_USER="net_admin"
USER_PASS="P@ssw0rd"

# ── SSH (на HQ-SRV / BR-SRV) ──
SSH_PORT="2026"
SSH_BANNER_TEXT="Authorized access only"

# ── DNS (HQ-SRV) ──
DNS_FORWARDER_1="77.88.8.7"
DNS_FORWARDER_2="77.88.8.3"

# ── Часовой пояс (по месту проведения экзамена) ──
TZ_REGION="Europe/Moscow"
